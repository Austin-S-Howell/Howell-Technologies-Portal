POC_API_ALLOWED_ORIGINS=https://portal.example.com
POC_API_FRONTEND_REDIRECT_URL=https://portal.example.com/demo-workbench
POC_API_SESSION_SAME_SITE=none
POC_API_SESSION_HTTPS_ONLY=true
POC_API_DATABASE_URL=sqlite:///./poc_api.db
POC_API_OPERATOR_USERS_SCHEMA=public
POC_API_OPERATOR_USERS_TABLE=operator_users
# Demo note: container-local SQLite on Cloud Run is ephemeral and not durable.
# For persistent storage, replace POC_API_DATABASE_URL with a managed database connection string.
# GitHub Actions alternative:
# - leave POC_API_DATABASE_URL unset
# - add GitHub secret POC_API_DB_PASSWORD
# - deploy with workflow inputs:
#   database_host=db.jikujruqahhyqwnlqmbt.supabase.co
#   database_port=5432
#   database_name=postgres
#   database_user=postgres
#   database_ssl_mode=require
